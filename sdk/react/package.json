{
  "name": "@trident-indexer/react",
  "version": "0.1.0",
  "description": "React hooks for the Trident Soroban event indexer",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "peerDependencies": {
    "react": ">=18.0.0"
  },
  "devDependencies": {
    "@testing-library/react": "^16.0.0",
    "@types/react": "^18.0.0 || ^19.0.0",
    "jsdom": "^25.0.0",
    "tsup": "^8.0.2",
    "typescript": "^5.3.3",
    "vitest": "^4.1.8"
  },
  "dependencies": {
    "@trident-indexer/sdk": "file:../typescript"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT"
}
